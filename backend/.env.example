# ── Arogya Sahayak Backend — Environment Variables ──
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# On Render: add these in Environment → Environment Variables

# ── Groq Free API Key (optional but recommended)
# Sign up FREE at: https://console.groq.com
# No credit card needed. 14,400 free requests/day.
# If not set, app uses built-in rule-based engine automatically.
GROQ_API_KEY=gsk_your_key_here

# ── Groq model to use (optional — default: llama-3.1-8b-instant)
# Options: llama-3.1-8b-instant | llama-3.3-70b-versatile | mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# ── Frontend URL for CORS (update with your Vercel URL)
FRONTEND_URL=https://arogya-sahayak.vercel.app

# ── Environment
ENVIRONMENT=production
